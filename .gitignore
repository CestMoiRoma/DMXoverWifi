# Auto-generated by CircuitPython on every boot, not project source
boot_out.txt

# OS / filesystem cruft injected by the CIRCUITPY mass-storage volume
.Trash-1000
.Trashes
.fseventsd/
.metadata_never_index
System Volume Information/

# Local secrets (wifi passwords, mqtt creds) - never commit runtime data
data/*.json
!data/.gitkeep

# Local deploy-time defaults (wifi passwords etc), see .env.example
.env

# Pre-existing SD card mount point, unrelated to this project
/sd/

__pycache__/
*.pyc

# Windows Recycle Bin metadata on this removable drive
$RECYCLE.BIN/
