# Copy to .env (gitignored) and fill in the values you want the board
# to start with on a fresh flash. tools/deploy.py reads this file and
# seeds data/*.json on the target.
#
# Default behavior:
#   - WiFi: merge (new SSIDs are appended, existing ones are left alone)
#   - Everything else: only write if the target file is missing
#     (so redeploying doesn't wipe changes you made through the UI)
#
# Force a full reset from this file with:  python tools/deploy.py --reset-config
#
# --- WiFi networks (numbered groups) ------------------------------------
# Priority is optional (default 0); higher wins when the board picks a
# network at boot.

WIFI_1_SSID=MyHomeWifi
WIFI_1_PASSWORD=changeme
WIFI_1_PRIORITY=10

WIFI_2_SSID=BackupHotspot
WIFI_2_PASSWORD=changeme
WIFI_2_PRIORITY=5

# --- MQTT ---------------------------------------------------------------

MQTT_ENABLED=false
MQTT_HOST=
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=dmxwifi
MQTT_DISCOVERY_PREFIX=homeassistant

# --- System / DMX / hotspot / static IP ----------------------------------

DMX_TX_PIN=D4
DMX_DIR_PIN_ENABLED=false
DMX_DIR_PIN=D3
HOSTNAME=ESP-DMX
AP_SSID=ESP-DMX
AP_PASSWORD=DMX4ALL1
AP_IP=1.1.1.1

STA_IP_MODE=dhcp
STA_STATIC_IP=
STA_STATIC_NETMASK=255.255.255.0
STA_STATIC_GATEWAY=
STA_STATIC_DNS=1.1.1.1

# --- Parent/Child mesh (WIP) ---------------------------------------------

MESH_ROLE=none
MESH_SSID=
MESH_PASSWORD=

# --- Devices (numbered groups, each with numbered channels) --------------
# type = slider | button | button-momentary | button-switch

# DEVICE_1_NAME=Studio Par
# DEVICE_1_START_CHANNEL=1
# DEVICE_1_CHANNEL_1_OFFSET=1
# DEVICE_1_CHANNEL_1_NAME=Red
# DEVICE_1_CHANNEL_1_TYPE=slider
# DEVICE_1_CHANNEL_2_OFFSET=2
# DEVICE_1_CHANNEL_2_NAME=Green
# DEVICE_1_CHANNEL_2_TYPE=slider
