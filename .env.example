# Copy to .env (which is gitignored) and fill in the networks you want
# the board to pre-know at first flash.
#
# tools/deploy.py reads this file and MERGES the entries into
# data/wifi_networks.json on the target: existing SSIDs on the board
# are left alone, new ones are appended.
#
# Numbered groups; the number just keeps entries paired. Priority is
# optional (default 0); higher wins when the board tries known networks
# at boot.

WIFI_1_SSID=MyHomeWifi
WIFI_1_PASSWORD=changeme
WIFI_1_PRIORITY=10

WIFI_2_SSID=BackupHotspot
WIFI_2_PASSWORD=changeme
WIFI_2_PRIORITY=5
